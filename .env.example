TZ=Asia/Shanghai
MODE=gui

# Management UI
NOVNC_BIND_ADDR=127.0.0.1
NOVNC_HOST_PORT=6080
UI_AUTH_USERNAME=
UI_AUTH_PASSWORD=
UI_PASSWORD=
UI_RATE_LIMIT_RPS=5
UI_RATE_LIMIT_BURST=20
UI_RATE_LIMIT_CONN=10

# Proxy port
PROXY_BIND_ADDR=127.0.0.1
PROXY_SOCKS_HOST_PORT=6454

# Optional admin ports, only used with docker-compose.admin-ports.yml
CONTROL_BIND_ADDR=127.0.0.1
CONTROL_HOST_PORT=19227
DNS_BIND_ADDR=127.0.0.1
DNS_HOST_PORT=1053

# Runtime display settings
XVFB_WHD=1280x800x24
