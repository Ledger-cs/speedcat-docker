TZ=Asia/Shanghai
MODE=gui

# Prebuilt image deployment
SPEEDCAT_IMAGE=einfash/speedcat-scclient:1.33.12
SPEEDCAT_PULL_POLICY=if_not_present

# Optional maintainer-only build override
# BASE_IMAGE=ubuntu:24.04

# Docker log driver limits
DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=3

# Optional in-container file logs for debugging
ENABLE_FILE_LOGS=0
LOG_DIR=/data/logs
FILE_LOG_MAX_BYTES=10485760
FILE_LOG_MAX_FILES=3

# Management UI
NOVNC_BIND_ADDR=127.0.0.1
NOVNC_HOST_PORT=6080
UI_AUTH_USERNAME=
UI_AUTH_PASSWORD=
UI_PASSWORD=
UI_RATE_LIMIT_RPS=5
UI_RATE_LIMIT_BURST=20
UI_RATE_LIMIT_CONN=10

# Proxy port
PROXY_BIND_ADDR=127.0.0.1
PROXY_SOCKS_HOST_PORT=6454

# Optional admin ports, only used with docker-compose.admin-ports.yml
CONTROL_BIND_ADDR=127.0.0.1
CONTROL_HOST_PORT=19227
DNS_BIND_ADDR=127.0.0.1
DNS_HOST_PORT=1053

# Runtime display settings
XVFB_WHD=1280x800x24
